MYSQL_HOST=127.0.0.1:3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASS=
AUTO_MIGRATE=true
CREATE_ADMIN=true
DUMMY_DATA=true
DISCORD_WEBHOOK_URL=
OPENAI_API_KEY=
DEV=true

# PostgreSQL (new -- replaces PocketBase/SQLite)
DATABASE_URL=postgres://createmod:localdev@localhost:5432/createmod?sslmode=disable

# Redis (replaces in-memory go-cache for multi-pod)
REDIS_URL=redis://localhost:6379/0

# S3/Minio (direct SDK -- replaces PocketBase filesystem API)
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=createmod
S3_USE_SSL=false

# OAuth providers
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
STEAM_API_KEY=

# Shared secret for Minecraft mod download API (HMAC signing)
MOD_DOWNLOAD_SECRET=

# Base URL for OAuth callbacks and sitemap generation
BASE_URL=http://localhost:8080

# Meilisearch (full-text search)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=

# Logging (debug, info, warn, error)
LOG_LEVEL=info
